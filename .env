###############################################################################
# Verify Platform
###############################################################################

EXPO_PUBLIC_API_BASE_URL=https://dev.m360.com.ph/verify/v1

###############################################################################
# OAuth
###############################################################################

EXPO_PUBLIC_VERIFY_CLIENT_ID=a

EXPO_PUBLIC_VERIFY_CLIENT_SECRET=a

###############################################################################
# Application
###############################################################################

EXPO_PUBLIC_APP_NAME=Verify Demo

EXPO_PUBLIC_APP_ENV=development

###############################################################################
# Networking
###############################################################################

EXPO_PUBLIC_API_TIMEOUT=10000

EXPO_PUBLIC_ENABLE_NETWORK_LOGGING=false
